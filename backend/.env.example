# Database
DATABASE_URL="postgresql://username:password@localhost:5432/thebrand"

# Server
PORT=3000
NODE_ENV="development"

# JWT Authentication
JWT_SECRET="your_very_secure_random_secret_key_change_this_in_production"
JWT_EXPIRATION="7d"

# Security
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN="*"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

